{
  "ConnectionStrings": {
    "GlobalConnection": "Server=tcp:cliniccare-prod.database.windows.net,1433;Database=ClinicCare_Global;User ID=clinicadmin;Password={AZURE_SQL_PASSWORD};Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;MultipleActiveResultSets=true",
    "TenantConnection": "Server=tcp:cliniccare-prod.database.windows.net,1433;Database=ClinicCare_{TenantId};User ID=clinicadmin;Password={AZURE_SQL_PASSWORD};Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "{JWT_KEY_FROM_AZURE_KEY_VAULT}",
    "Issuer": "ClinicCare",
    "Audience": "ClinicCareUsers",
    "ExpirationInDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "EnableWhatsAppIntegration": true,
    "EnableEmailNotifications": true,
    "EnableSMSNotifications": true
  },
  "ApplicationInsights": {
    "ConnectionString": "{APPINSIGHTS_CONNECTION_STRING}"
  },
  "Azure": {
    "KeyVault": {
      "VaultUri": "https://cliniccare-kv.vault.azure.net/"
    },
    "Storage": {
      "ConnectionString": "{AZURE_STORAGE_CONNECTION_STRING}",
      "ContainerName": "clinic-documents"
    }
  }
}















