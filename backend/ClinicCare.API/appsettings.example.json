{
  "TenantSettings": {
    "DefaultConnectionString": "Server=(localdb)\\mssqllocaldb;Database={database};Trusted_Connection=True;MultipleActiveResultSets=true",
    "DatabaseNameTemplate": "ClinicCare_{tenant}",
    "Tenants": [
      {
        "Name": "Healthcare Plus",
        "Subdomain": "healthcareplus",
        "IsActive": true
      },
      {
        "Name": "City Clinic",
        "Subdomain": "cityclinic",
        "IsActive": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-super-secret-key-here",
    "Issuer": "ClinicCare",
    "Audience": "ClinicCareUsers",
    "ExpirationInDays": 7
  }
}